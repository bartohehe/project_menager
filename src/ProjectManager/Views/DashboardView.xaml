<UserControl x:Class="ProjectManager.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ProjectManager.Converters"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToTextConverter x:Key="StatusToText"/>
        <conv:RelativeDateConverter x:Key="RelativeDate"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
        <StackPanel Margin="32,28">
            <!-- Header -->
            <TextBlock Text="Pulpit" Style="{StaticResource SectionHeader}" FontSize="24"/>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource BrushDanger}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"
                       Margin="0,0,0,16" FontFamily="Segoe UI"/>

            <!-- KPI Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,32">
                <!-- Completed -->
                <Border Style="{StaticResource CardBorderStatic}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="40" Height="40" CornerRadius="8"
                                    Background="#1A3D2A" Margin="0,0,12,0">
                                <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="#22C55E"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Ukończone" FontSize="14"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CompletedCount}" FontSize="36" FontWeight="Bold"
                                   Foreground="#22C55E" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- In Progress -->
                <Border Style="{StaticResource CardBorderStatic}" Margin="6,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="40" Height="40" CornerRadius="8"
                                    Background="#3D3520" Margin="0,0,12,0">
                                <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="#FBBF24"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="W trakcie" FontSize="14"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <TextBlock Text="{Binding InProgressCount}" FontSize="36" FontWeight="Bold"
                                   Foreground="#FBBF24" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Planned -->
                <Border Style="{StaticResource CardBorderStatic}" Margin="12,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="40" Height="40" CornerRadius="8"
                                    Background="#1A2545" Margin="0,0,12,0">
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="#3B82F6"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Planowane" FontSize="14"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <TextBlock Text="{Binding PlannedCount}" FontSize="36" FontWeight="Bold"
                                   Foreground="#3B82F6" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent Projects -->
            <TextBlock Text="Ostatnio aktualizowane" Style="{StaticResource SectionHeader}"/>

            <!-- Loading -->
            <TextBlock Text="Ładowanie..." Foreground="{StaticResource BrushTextMuted}"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                       FontFamily="Segoe UI" Margin="0,0,0,12"/>

            <!-- Project List -->
            <ItemsControl ItemsSource="{Binding RecentProjects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{StaticResource BrushBgCard}"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="20,16" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontSize="15"
                                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                                           Foreground="{StaticResource BrushTextPrimary}"/>
                                                <TextBlock Text="{Binding Category}" FontSize="12"
                                                           Foreground="{StaticResource BrushTextMuted}"
                                                           FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" Style="{StaticResource StatusBadge}"
                                                    Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                    Opacity="0.85" VerticalAlignment="Center" Margin="12,0">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           Foreground="White"
                                                           FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                                            </Border>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding UpdatedAt, Converter={StaticResource RelativeDate}}"
                                                       Foreground="{StaticResource BrushTextMuted}" FontSize="12"
                                                       VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushBgHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty State -->
            <Border Style="{StaticResource CardBorderStatic}" Margin="0,8"
                    Visibility="{Binding RecentProjects.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center" Margin="0,24">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                               Foreground="{StaticResource BrushTextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Brak projektów" FontSize="16" Foreground="{StaticResource BrushTextSecondary}"
                               HorizontalAlignment="Center" Margin="0,12,0,0" FontFamily="Segoe UI"/>
                    <TextBlock Text="Utwórz swój pierwszy projekt" FontSize="13"
                               Foreground="{StaticResource BrushTextMuted}"
                               HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
