<UserControl x:Class="ProjectManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ProjectManager.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
        <StackPanel Margin="32,28" MaxWidth="700" HorizontalAlignment="Left">
            <TextBlock Text="Ustawienia" Style="{StaticResource SectionHeader}" FontSize="24"/>

            <!-- Connection Section -->
            <Border Style="{StaticResource CardBorderStatic}" Padding="28" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Połączenie z bazą danych" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Wprowadź MongoDB connection string. Będzie zaszyfrowany i zapisany lokalnie."
                               Foreground="{StaticResource BrushTextSecondary}" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <!-- Status Indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource BrushDanger}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource BrushStatusCompleted}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="13" FontFamily="Segoe UI"
                                   Foreground="{StaticResource BrushTextSecondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Brak połączenia"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="Połączono"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Connection String Input -->
                    <TextBlock Text="Connection String" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Tag="mongodb+srv://user:pass@cluster.mongodb.net"
                             Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <!-- Status Message -->
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="Segoe UI" Margin="0,0,0,16"
                               Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Testuj połączenie" Style="{StaticResource FlatButton}"
                                Command="{Binding TestConnectionCommand}" Margin="0,0,8,0"/>
                        <Button Content="Zapisz i połącz" Style="{StaticResource AccentButton}"
                                Command="{Binding SaveConnectionCommand}" Margin="0,0,8,0"/>
                        <Button Content="Usuń" Style="{StaticResource FlatButton}"
                                Command="{Binding ClearConnectionCommand}"
                                Foreground="{StaticResource BrushDanger}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Info -->
            <Border Style="{StaticResource CardBorderStatic}" Padding="28">
                <StackPanel>
                    <TextBlock Text="Bezpieczeństwo" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" FontFamily="Segoe UI"
                               Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="Segoe UI" LineHeight="22">
                        Connection string jest szyfrowany za pomocą Windows DPAPI i zapisywany
                        w katalogu %LocalAppData%\ProjectManager. Klucz szyfrowania jest powiązany
                        z Twoim kontem Windows — nikt inny nie odczyta zapisanych danych.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
