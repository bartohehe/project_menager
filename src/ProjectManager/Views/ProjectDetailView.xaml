<UserControl x:Class="ProjectManager.Views.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ProjectManager.Converters"
             xmlns:models="clr-namespace:ProjectManager.Models"
             xmlns:helpers="clr-namespace:ProjectManager.Helpers">

    <UserControl.Resources>
        <conv:StatusToColorConverter     x:Key="StatusToColor"/>
        <conv:StatusToTextConverter      x:Key="StatusToText"/>
        <conv:DateFormatConverter        x:Key="DateFormat"/>
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter  x:Key="NullToVis"/>
        <conv:FileSizeConverter          x:Key="FileSize"/>
        <conv:ByteArrayToImageConverter  x:Key="BytesToImage"/>

        <!-- ── Shared card container style ── -->
        <Style x:Key="SectionCardBorder" TargetType="Border">
            <Setter Property="Width"           Value="300"/>
            <Setter Property="MinHeight"       Value="160"/>
            <Setter Property="Margin"          Value="6"/>
            <Setter Property="Background"      Value="{DynamicResource BrushBgCard}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="ClipToBounds"    Value="True"/>
            <Setter Property="AllowDrop"       Value="True"/>
        </Style>

        <!-- ════════════════════════════════════════════
             DataTemplateSelector inline definitions
             ════════════════════════════════════════════ -->
        <helpers:SectionCardTemplateSelector x:Key="CardSelector">

            <!-- ── OPIS ── -->
            <helpers:SectionCardTemplateSelector.DescriptionTemplate>
                <DataTemplate DataType="{x:Type models:SectionCard}">
                    <Border Style="{StaticResource SectionCardBorder}"
                            DragOver="Card_DragOver" DragLeave="Card_DragLeave" Drop="Card_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- header -->
                            <Border Grid.Row="0" BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="0,0,0,1" Padding="14,10">
                                <TextBlock Text="Opis" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Border>
                            <!-- content -->
                            <StackPanel Grid.Row="1" Margin="14,10">
                                <TextBlock FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           Text="{Binding DataContext.Project.Description,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Visibility="{Binding DataContext.IsEditing,
                                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                                        Converter={StaticResource BoolToVis},
                                                        ConverterParameter=Invert}"/>
                                <TextBox Style="{StaticResource DarkTextBox}" TextWrapping="Wrap"
                                         AcceptsReturn="True" MinHeight="90"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding DataContext.EditDescription, UpdateSourceTrigger=PropertyChanged,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         Visibility="{Binding DataContext.IsEditing,
                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                      Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                            <!-- drag overlay -->
                            <Border Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="5"
                                    Background="#28141B2A" Cursor="SizeAll"
                                    PreviewMouseLeftButtonDown="Card_MouseDown"
                                    MouseMove="Card_MouseMove"
                                    Visibility="{Binding DataContext.IsLayoutEditing,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </helpers:SectionCardTemplateSelector.DescriptionTemplate>

            <!-- ── ZDJĘCIA ── -->
            <helpers:SectionCardTemplateSelector.PhotosTemplate>
                <DataTemplate DataType="{x:Type models:SectionCard}">
                    <Border Style="{StaticResource SectionCardBorder}"
                            DragOver="Card_DragOver" DragLeave="Card_DragLeave" Drop="Card_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="0,0,0,1" Padding="14,10">
                                <Grid>
                                    <TextBlock Text="Zdjęcia" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <Button Style="{StaticResource IconButton}" Width="26" Height="26"
                                            HorizontalAlignment="Right"
                                            Command="{Binding DataContext.AddPhotoCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" Foreground="{DynamicResource BrushAccent}"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Row="1" Margin="14,10">
                                <ItemsControl ItemsSource="{Binding DataContext.GalleryImages,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BrushBgDark}"
                                                    CornerRadius="6" Margin="0,0,6,6"
                                                    Width="78" Height="58" ClipToBounds="True">
                                                <Image Source="{Binding Converter={StaticResource BytesToImage}}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Brak zdjęć" FontSize="12" FontFamily="Segoe UI"
                                           FontStyle="Italic" Foreground="{DynamicResource BrushTextMuted}"
                                           Visibility="{Binding DataContext.GalleryImages.Count,
                                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                                        Converter={StaticResource BoolToVis},
                                                        ConverterParameter=Invert}"/>
                            </StackPanel>
                            <Border Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="5"
                                    Background="#28141B2A" Cursor="SizeAll"
                                    PreviewMouseLeftButtonDown="Card_MouseDown"
                                    MouseMove="Card_MouseMove"
                                    Visibility="{Binding DataContext.IsLayoutEditing,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </helpers:SectionCardTemplateSelector.PhotosTemplate>

            <!-- ── ZAŁĄCZNIKI ── -->
            <helpers:SectionCardTemplateSelector.AttachmentsTemplate>
                <DataTemplate DataType="{x:Type models:SectionCard}">
                    <Border Style="{StaticResource SectionCardBorder}"
                            DragOver="Card_DragOver" DragLeave="Card_DragLeave" Drop="Card_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="0,0,0,1" Padding="14,10">
                                <Grid>
                                    <TextBlock Text="Załączniki" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <Button Style="{StaticResource IconButton}" Width="26" Height="26"
                                            HorizontalAlignment="Right"
                                            Command="{Binding DataContext.AddAttachmentCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" Foreground="{DynamicResource BrushAccent}"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Row="1" Margin="14,10">
                                <ItemsControl ItemsSource="{Binding DataContext.Attachments,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8A5;"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="{DynamicResource BrushTextMuted}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FileName}"
                                                           FontSize="12" FontFamily="Segoe UI"
                                                           Foreground="{DynamicResource BrushTextSecondary}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="2" Style="{StaticResource IconButton}"
                                                        Width="24" Height="24" Margin="4,0,0,0"
                                                        Command="{Binding DataContext.DownloadAttachmentCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                                </Button>
                                                <Button Grid.Column="3" Style="{StaticResource IconButton}"
                                                        Width="24" Height="24" Margin="2,0,0,0"
                                                        Command="{Binding DataContext.DeleteAttachmentCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10" Foreground="{DynamicResource BrushDanger}"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Brak załączników" FontSize="12" FontFamily="Segoe UI"
                                           FontStyle="Italic" Foreground="{DynamicResource BrushTextMuted}"
                                           Visibility="{Binding DataContext.Attachments.Count,
                                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                                        Converter={StaticResource BoolToVis},
                                                        ConverterParameter=Invert}"/>
                            </StackPanel>
                            <Border Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="5"
                                    Background="#28141B2A" Cursor="SizeAll"
                                    PreviewMouseLeftButtonDown="Card_MouseDown"
                                    MouseMove="Card_MouseMove"
                                    Visibility="{Binding DataContext.IsLayoutEditing,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </helpers:SectionCardTemplateSelector.AttachmentsTemplate>

            <!-- ── SEKCJA NIESTANDARDOWA ── -->
            <helpers:SectionCardTemplateSelector.CustomTemplate>
                <DataTemplate DataType="{x:Type models:SectionCard}">
                    <Border Style="{StaticResource SectionCardBorder}"
                            DragOver="Card_DragOver" DragLeave="Card_DragLeave" Drop="Card_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="0,0,0,1" Padding="14,10">
                                <TextBlock Text="{Binding Section.Title}" FontSize="13"
                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Border>
                            <TextBlock Grid.Row="1" Text="{Binding Section.Content}"
                                       FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="14,10"/>
                            <Border Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="5"
                                    Background="#28141B2A" Cursor="SizeAll"
                                    PreviewMouseLeftButtonDown="Card_MouseDown"
                                    MouseMove="Card_MouseMove"
                                    Visibility="{Binding DataContext.IsLayoutEditing,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </helpers:SectionCardTemplateSelector.CustomTemplate>

        </helpers:SectionCardTemplateSelector>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════
         ROOT
         ═══════════════════════════════════════════════════════ -->
    <Grid>
        <!-- Loading overlay -->
        <Border Background="#C0000000" Panel.ZIndex="20"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                           Foreground="{DynamicResource BrushAccent}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Ładowanie..." FontSize="14" FontFamily="Segoe UI"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- header info -->
                <RowDefinition Height="Auto"/>  <!-- tab bar -->
                <RowDefinition Height="*"/>     <!-- content -->
                <RowDefinition Height="56"/>    <!-- bottom bar -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════
                 ROW 0 — Project info header
                 ══════════════════════════════════════ -->
            <Border Grid.Row="0" Background="{DynamicResource BrushBgPanel}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- VIEW MODE -->
                    <StackPanel Grid.Column="0"
                                Visibility="{Binding IsEditing,
                                             Converter={StaticResource BoolToVis},
                                             ConverterParameter=Invert}">
                        <TextBlock Text="{Binding Project.Name}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextPrimary}" FontFamily="Segoe UI"
                                   Margin="0,0,0,8"/>
                        <WrapPanel>
                            <Border CornerRadius="10" Padding="10,4" Margin="0,0,12,0"
                                    Background="{Binding Project.Status, Converter={StaticResource StatusToColor}}"
                                    Opacity="0.85" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Project.Status, Converter={StaticResource StatusToText}}"
                                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                                           FontFamily="Segoe UI"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center"
                                        Visibility="{Binding Project.Category, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,5,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Project.Category}"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center"
                                        Visibility="{Binding Project.StartDate, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,5,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Project.StartDate, Converter={StaticResource DateFormat}}"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        Visibility="{Binding Project.Price, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,5,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Foreground="{DynamicResource BrushTextSecondary}"
                                           FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center">
                                    <Run Text="{Binding Project.Price, StringFormat='{}{0:N2}', Mode=OneWay}"/>
                                    <Run Text="{Binding Project.Currency, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <!-- EDIT MODE -->
                    <StackPanel Grid.Column="0"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" FontSize="16" FontWeight="SemiBold"
                                 Tag="Nazwa projektu..." Margin="0,0,0,10"/>
                        <WrapPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Status" FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,3"/>
                                <ComboBox Style="{StaticResource DarkComboBox}" Width="130"
                                          ItemsSource="{x:Static conv:StatusToTextConverter.AllStatuses}"
                                          SelectedItem="{Binding EditStatus}"
                                          ItemContainerStyle="{StaticResource DarkComboBoxItem}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource StatusToText}}"
                                                       FontFamily="Segoe UI" FontSize="13"
                                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Rozpoczęcie" FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,3"/>
                                <DatePicker SelectedDate="{Binding EditStartDate}" Width="148"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Zakończenie" FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,3"/>
                                <DatePicker SelectedDate="{Binding EditEndDate}" Width="148"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Cena" FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding EditPrice, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}" Tag="0.00" Width="110"/>
                            </StackPanel>
                        </WrapPanel>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource BrushDanger}"
                                   FontFamily="Segoe UI" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Header right: edit / save / cancel buttons -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal"
                                Margin="16,0,0,0">
                        <!-- When NOT editing -->
                        <Button Style="{StaticResource IconButton}" Width="34" Height="34"
                                Command="{Binding ToggleEditCommand}"
                                ToolTip="Edytuj informacje o projekcie"
                                Visibility="{Binding IsEditing,
                                             Converter={StaticResource BoolToVis},
                                             ConverterParameter=Invert}">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </Button>
                        <!-- When editing -->
                        <Button Content="Zapisz" Style="{StaticResource AccentButton}"
                                Padding="16,7" Margin="0,0,8,0"
                                Command="{Binding SaveCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Anuluj" Style="{StaticResource FlatButton}"
                                Padding="12,7"
                                Command="{Binding ToggleEditCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════
                 ROW 1 — Tab bar
                 ══════════════════════════════════════ -->
            <Border Grid.Row="1" Background="{DynamicResource BrushBgPanel}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Widok ogólny" GroupName="DetailTabs"
                                     IsChecked="{Binding IsGeneralTab, Mode=OneWay}"
                                     Command="{Binding SwitchTabCommand}" CommandParameter="0">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="{DynamicResource BrushTextSecondary}"/>
                                    <Setter Property="FontSize"    Value="13"/>
                                    <Setter Property="FontFamily"  Value="Segoe UI"/>
                                    <Setter Property="Padding"     Value="0,14"/>
                                    <Setter Property="Margin"      Value="0,0,28,0"/>
                                    <Setter Property="Cursor"      Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                        BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                                    <ContentPresenter VerticalAlignment="Center"
                                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                        <RadioButton Content="Timeline" GroupName="DetailTabs"
                                     IsChecked="{Binding IsTimelineTab, Mode=OneWay}"
                                     Command="{Binding SwitchTabCommand}" CommandParameter="1">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="{DynamicResource BrushTextSecondary}"/>
                                    <Setter Property="FontSize"    Value="13"/>
                                    <Setter Property="FontFamily"  Value="Segoe UI"/>
                                    <Setter Property="Padding"     Value="0,14"/>
                                    <Setter Property="Cursor"      Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                        BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                                    <ContentPresenter VerticalAlignment="Center"
                                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                    </StackPanel>
                    <!-- Context action (right) -->
                    <Button HorizontalAlignment="Right" Style="{StaticResource FlatButton}"
                            Padding="12,6" FontSize="12"
                            Visibility="{Binding IsGeneralTab, Converter={StaticResource BoolToVis}}"
                            Click="OnAddSection">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Margin="0,0,6,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource BrushAccent}"/>
                            <TextBlock Text="Dodaj sekcję" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button HorizontalAlignment="Right" Style="{StaticResource FlatButton}"
                            Padding="12,6" FontSize="12"
                            Visibility="{Binding IsTimelineTab, Converter={StaticResource BoolToVis}}"
                            Click="OnAddTimelineEntry">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Margin="0,0,6,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource BrushAccent}"/>
                            <TextBlock Text="Dodaj wpis" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════
                 ROW 2 — WIDOK OGÓLNY
                 ══════════════════════════════════════ -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource DarkScrollViewer}"
                          Visibility="{Binding IsGeneralTab, Converter={StaticResource BoolToVis}}">

                <!-- Layout-editing banner -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A00BC8C" BorderBrush="{DynamicResource BrushAccent}"
                            BorderThickness="0,0,0,1" Padding="24,10"
                            Visibility="{Binding IsLayoutEditing, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource BrushAccent}" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Tryb aranżacji — przeciągnij karty, aby zmienić ich kolejność"
                                       FontFamily="Segoe UI" FontSize="13"
                                       Foreground="{DynamicResource BrushAccent}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding SectionCards}"
                                  ItemTemplateSelector="{StaticResource CardSelector}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Margin="18,18,18,24" Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- ══════════════════════════════════════
                 ROW 2 — TIMELINE (horizontal)
                 ══════════════════════════════════════ -->
            <ScrollViewer Grid.Row="2"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Style="{StaticResource DarkScrollViewer}"
                          Visibility="{Binding IsTimelineTab, Converter={StaticResource BoolToVis}}">
                <Grid Height="300" Margin="24,32,24,32" VerticalAlignment="Top">
                    <!-- Background line -->
                    <Border Height="2" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00BC8C" Offset="0"/>
                                <GradientStop Color="#00BC8C" Offset="0.7"/>
                                <GradientStop Color="#283750" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Items -->
                    <ItemsControl ItemsSource="{Binding TimelineEntries}"
                                  AlternationCount="2" VerticalAlignment="Stretch">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Tag"
                                        Value="{Binding RelativeSource={RelativeSource Self},
                                               Path=(ItemsControl.AlternationIndex)}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="170" Height="300">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border x:Name="TopCard" Grid.Row="0" VerticalAlignment="Bottom"
                                            Margin="8,0,8,14"
                                            Background="{DynamicResource BrushBgCard}"
                                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,10" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       Margin="0,4,0,0"
                                                       Visibility="{Binding Description, Converter={StaticResource NullToVis}}"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock x:Name="TopDate" Grid.Row="0"
                                               Text="{Binding Date, Converter={StaticResource DateFormat}}"
                                               VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                               Margin="0,0,0,10" FontSize="11" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               Visibility="Collapsed"/>
                                    <Ellipse Grid.Row="1" Width="14" Height="14" Margin="0,-6,0,-6"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Fill="{Binding Type, Converter={StaticResource StatusToColor}}"
                                             Stroke="{DynamicResource BrushBgDark}" StrokeThickness="2"
                                             Panel.ZIndex="1"/>
                                    <TextBlock x:Name="BottomDate" Grid.Row="2"
                                               Text="{Binding Date, Converter={StaticResource DateFormat}}"
                                               VerticalAlignment="Top" HorizontalAlignment="Center"
                                               Margin="0,10,0,0" FontSize="11" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               Visibility="Collapsed"/>
                                    <Border x:Name="BottomCard" Grid.Row="2" VerticalAlignment="Top"
                                            Margin="8,14,8,0"
                                            Background="{DynamicResource BrushBgCard}"
                                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,10" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       Margin="0,4,0,0"
                                                       Visibility="{Binding Description, Converter={StaticResource NullToVis}}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Tag,
                                             RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                             Value="0">
                                    <Setter TargetName="TopCard"    Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="BottomDate" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tag,
                                             RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                             Value="1">
                                    <Setter TargetName="TopDate"    Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="BottomCard" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Brak wpisów na osi czasu"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="14" FontFamily="Segoe UI" FontStyle="Italic"
                               Foreground="{DynamicResource BrushTextMuted}"
                               Visibility="{Binding TimelineEntries.Count,
                                            Converter={StaticResource BoolToVis},
                                            ConverterParameter=Invert}"/>
                </Grid>
            </ScrollViewer>

            <!-- ══════════════════════════════════════
                 ROW 3 — Bottom action bar
                 ══════════════════════════════════════ -->
            <Border Grid.Row="3" Background="{DynamicResource BrushBgPanel}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <!-- Left: layout edit toggle -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <!-- Normal state -->
                        <Button Content="Edytuj układ" Style="{StaticResource FlatButton}"
                                Padding="16,8"
                                Command="{Binding ToggleLayoutEditCommand}"
                                Visibility="{Binding IsLayoutEditing,
                                             Converter={StaticResource BoolToVis},
                                             ConverterParameter=Invert}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <TextBlock Text="Edytuj układ" FontFamily="Segoe UI" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <!-- Layout editing state: save + cancel -->
                        <Button Content="Zapisz układ" Style="{StaticResource AccentButton}"
                                Padding="16,8" Margin="0,0,8,0"
                                Command="{Binding SaveLayoutCommand}"
                                Visibility="{Binding IsLayoutEditing, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Anuluj" Style="{StaticResource FlatButton}"
                                Padding="12,8"
                                Command="{Binding ToggleLayoutEditCommand}"
                                Visibility="{Binding IsLayoutEditing, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Right: delete -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource DangerButton}" Padding="16,8"
                            Click="OnDeleteProject">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Usuń projekt" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
