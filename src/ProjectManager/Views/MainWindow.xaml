<Window x:Class="ProjectManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProjectManager.ViewModels"
        Title="Project Manager" Width="1400" Height="900"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="#0D111B">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="42" ResizeBorderThickness="6"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#141B2A" BorderBrush="#283750"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="#00BC8C" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Project Manager" FontSize="14" FontWeight="SemiBold"
                               Foreground="#F0F5FF" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock Text=" — " Foreground="#506487" VerticalAlignment="Center"
                               FontFamily="Segoe UI" Margin="4,0"/>
                    <TextBlock Text="{Binding CurrentViewTitle}" Foreground="#8296B9"
                               VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="13"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" Style="{StaticResource WinChromeButton}"
                            Command="{Binding MinimizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button x:Name="MaximizeBtn" Content="&#xE922;"
                            Style="{StaticResource WinChromeButton}"
                            Command="{Binding ToggleMaximizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource WinChromeButtonClose}"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#141B2A" BorderBrush="#283750"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                        <Border Height="1" Background="#283750" Margin="16,8"/>
                        <RadioButton Content="Ustawienia" Tag="&#xE713;"
                                     Style="{StaticResource NavButton}" GroupName="Nav"
                                     Command="{Binding NavigateToSettingsCommand}"/>
                    </StackPanel>

                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="MENU" FontSize="10" FontWeight="Bold"
                                   Foreground="#506487" Margin="20,12,0,8"
                                   FontFamily="Segoe UI"/>
                        <RadioButton Content="Pulpit" Tag="&#xE80F;"
                                     Style="{StaticResource NavButton}" GroupName="Nav"
                                     IsChecked="True"
                                     Command="{Binding NavigateToDashboardCommand}"/>
                        <RadioButton Content="Projekty" Tag="&#xE8B7;"
                                     Style="{StaticResource NavButton}" GroupName="Nav"
                                     Command="{Binding NavigateToProjectListCommand}"/>
                        <!-- Orange accent "Nowy projekt" button -->
                        <Button Content="+ Nowy projekt"
                                Margin="12,4,12,4" Height="38"
                                Command="{Binding NavigateToNewProjectCommand}"
                                Style="{StaticResource AccentButton}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main Content -->
            <Border Grid.Column="1" Background="#0D111B">
                <ContentControl Content="{Binding CurrentView}" Margin="0"/>
            </Border>
        </Grid>
    </Grid>
</Window>
