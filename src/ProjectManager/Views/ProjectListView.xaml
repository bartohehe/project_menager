<UserControl x:Class="ProjectManager.Views.ProjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ProjectManager.Converters"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToTextConverter x:Key="StatusToText"/>
        <conv:RelativeDateConverter x:Key="RelativeDate"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Projekty" Style="{StaticResource SectionHeader}" FontSize="24"
                       VerticalAlignment="Center" Margin="0"/>
            <Button Content="+ Nowy projekt" Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Right" Command="{Binding AddNewProjectCommand}"/>
        </Grid>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStatic}" Margin="0,0,0,20" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                         Text="{Binding FilterName, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Szukaj po nazwie..." Margin="0,0,12,0"/>

                <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding FilterCategory}"
                          ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                          Width="180" Margin="0,0,12,0"/>

                <DatePicker Grid.Column="2" SelectedDate="{Binding FilterStartDate}"
                            Width="160" Margin="0,0,12,0"/>

                <Button Grid.Column="3" Content="Filtruj" Style="{StaticResource AccentButton}"
                        Command="{Binding ApplyFiltersCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="4" Content="Wyczyść" Style="{StaticResource FlatButton}"
                        Command="{Binding ClearFiltersCommand}"/>
            </Grid>
        </Border>

        <!-- Projects Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource DarkScrollViewer}">
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,16,16">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{StaticResource BrushBgCard}"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1" CornerRadius="10"
                                            Width="320" Padding="20">
                                        <StackPanel>
                                            <!-- Status Badge -->
                                            <Border Style="{StaticResource StatusBadge}" Margin="0,0,0,12"
                                                    Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                    Opacity="0.85">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           Foreground="White"
                                                           FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                            </Border>

                                            <!-- Name -->
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrushTextPrimary}"
                                                       FontFamily="Segoe UI" TextTrimming="CharacterEllipsis"/>

                                            <!-- Category -->
                                            <TextBlock Text="{Binding Category}" FontSize="12"
                                                       Foreground="{StaticResource BrushAccent}"
                                                       FontFamily="Segoe UI" Margin="0,6,0,0"/>

                                            <!-- Short Description -->
                                            <TextBlock Text="{Binding ShortDescription}" FontSize="13"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       FontFamily="Segoe UI" Margin="0,8,0,0"
                                                       TextWrapping="Wrap" MaxHeight="40"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,14"/>

                                            <!-- Footer -->
                                            <TextBlock FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                                                       FontFamily="Segoe UI">
                                                <Run Text="Aktualizacja: "/>
                                                <Run Text="{Binding UpdatedAt, Converter={StaticResource RelativeDate}, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushBgHover}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Error -->
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource BrushDanger}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"
                   FontFamily="Segoe UI" Margin="0,0,0,8" VerticalAlignment="Bottom"/>
    </Grid>
</UserControl>
