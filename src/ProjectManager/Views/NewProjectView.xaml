<UserControl x:Class="ProjectManager.Views.NewProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ProjectManager.Converters"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
        <StackPanel Margin="32,28" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Nowy projekt" Style="{StaticResource SectionHeader}" FontSize="24"/>
            <TextBlock Text="Utwórz nowy projekt w statusie planowania."
                       Foreground="{StaticResource BrushTextSecondary}" FontFamily="Segoe UI"
                       Margin="0,0,0,28"/>

            <Border Style="{StaticResource CardBorderStatic}" Padding="28">
                <StackPanel>
                    <!-- Name -->
                    <TextBlock Text="Nazwa projektu *" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Tag="Wprowadź nazwę projektu..."
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20"/>

                    <!-- Category -->
                    <TextBlock Text="Kategoria" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                              Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Tag="...lub wpisz nową kategorię"
                             Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20"/>

                    <!-- Short Description -->
                    <TextBlock Text="Krótki opis" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Tag="Krótki opis projektu..."
                             Text="{Binding ShortDescription, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="80" MaxHeight="160"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,24"/>

                    <!-- Error -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource BrushDanger}"
                               FontFamily="Segoe UI" Margin="0,0,0,12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"/>

                    <!-- Success -->
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource BrushStatusCompleted}"
                               FontFamily="Segoe UI" Margin="0,0,0,12"
                               Visibility="{Binding SuccessMessage, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"/>

                    <!-- Submit -->
                    <Button Content="Utwórz projekt"
                            Command="{Binding CreateProjectCommand}"
                            HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
