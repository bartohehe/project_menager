<Window x:Class="ProjectManager.Views.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potwierdzenie" Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#141B2A" ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#283750" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#141B2A" CornerRadius="8,8,0,0">
                <Grid>
                    <TextBlock x:Name="TitleText" Text="Potwierdzenie" FontSize="13"
                               FontFamily="Segoe UI" Foreground="#F0F5FF"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource WinChromeButtonClose}"
                            HorizontalAlignment="Right" Click="OnCancel"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,24">
                <TextBlock x:Name="MessageText" Text="Czy na pewno?"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontFamily="Segoe UI" FontSize="14" TextWrapping="Wrap"
                           Margin="0,0,0,24"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Anuluj" Style="{StaticResource FlatButton}"
                            Margin="0,0,8,0" Click="OnCancel"/>
                    <Button x:Name="ConfirmBtn" Content="Potwierdź"
                            Style="{StaticResource AccentButton}" Click="OnConfirm"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
