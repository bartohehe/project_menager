<Window x:Class="ProjectManager.Views.Dialogs.AddSectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj sekcję" Width="480" SizeToContent="Height" MinHeight="200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#141B2A" ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#283750" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#141B2A" CornerRadius="8,8,0,0">
                <Grid>
                    <TextBlock Text="Dodaj nową sekcję" FontSize="13" FontFamily="Segoe UI"
                               Foreground="#F0F5FF" VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource WinChromeButtonClose}"
                            HorizontalAlignment="Right" Click="OnCancel"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,16,24,24">
                <TextBlock Text="Tytuł sekcji *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TitleBox" Style="{StaticResource DarkTextBox}"
                         Tag="Np. Materiały, Koszty, Notatki..." Margin="0,0,0,16"/>

                <TextBlock Text="Zawartość" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ContentBox" Style="{StaticResource DarkTextBox}"
                         Tag="Treść sekcji (opcjonalna)..." TextWrapping="Wrap"
                         AcceptsReturn="True" MinHeight="80" Margin="0,0,0,24"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Anuluj" Style="{StaticResource FlatButton}"
                            Margin="0,0,8,0" Click="OnCancel"/>
                    <Button Content="Dodaj" Style="{StaticResource AccentButton}" Click="OnConfirm"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
