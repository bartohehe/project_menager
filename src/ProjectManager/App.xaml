<Application x:Class="ProjectManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ProjectManager.ViewModels"
             xmlns:views="clr-namespace:ProjectManager.Views">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ViewModel to View DataTemplates -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
                <views:ProjectListView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProjectDetailViewModel}">
                <views:ProjectDetailView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:NewProjectViewModel}">
                <views:NewProjectView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
