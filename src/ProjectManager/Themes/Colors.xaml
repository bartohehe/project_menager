<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BrushBgDark" Color="#0D111B"/>
    <SolidColorBrush x:Key="BrushBgPanel" Color="#141B2A"/>
    <SolidColorBrush x:Key="BrushBgCard" Color="#1A2335"/>
    <SolidColorBrush x:Key="BrushBgHover" Color="#212C42"/>
    <SolidColorBrush x:Key="BrushBorder" Color="#283750"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="BrushAccent" Color="#00BC8C"/>
    <SolidColorBrush x:Key="BrushAccentHover" Color="#00D2A0"/>
    <SolidColorBrush x:Key="BrushAccentBlue" Color="#3B82F6"/>
    <SolidColorBrush x:Key="BrushAccentPurple" Color="#8B5CF6"/>

    <!-- Text -->
    <SolidColorBrush x:Key="BrushTextPrimary" Color="#F0F5FF"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#8296B9"/>
    <SolidColorBrush x:Key="BrushTextMuted" Color="#506487"/>

    <!-- Status -->
    <SolidColorBrush x:Key="BrushStatusPlanned" Color="#3B82F6"/>
    <SolidColorBrush x:Key="BrushStatusInProgress" Color="#FBBF24"/>
    <SolidColorBrush x:Key="BrushStatusCompleted" Color="#22C55E"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="BrushDanger" Color="#EF4444"/>
    <SolidColorBrush x:Key="BrushDangerHover" Color="#FF6464"/>

</ResourceDictionary>
